# Application
NODE_ENV=development
LOG_LEVEL=debug

# API Gateway
API_PORT=3001
API_HOST=0.0.0.0

# Web Application
WEB_PORT=3000

# Mobile Application
MOBILE_PORT=8081

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=swipejobs
DATABASE_PASSWORD=swipejobs_dev_password
DATABASE_NAME=swipejobs_os
DATABASE_URL=postgresql://swipejobs:swipejobs_dev_password@localhost:5432/swipejobs_os

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Elasticsearch
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_INDEX_PREFIX=swipejobs

# Kafka
KAFKA_BROKERS=kafka:29092
KAFKA_GROUP_ID=swipejobs-consumer
KAFKA_CLIENT_ID=swipejobs-producer

# JWT
JWT_SECRET=your_jwt_secret_key_here_min_32_chars
JWT_EXPIRATION=1h
JWT_REFRESH_SECRET=your_refresh_secret_key_here_min_32_chars
JWT_REFRESH_EXPIRATION=7d

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=swipejobs-files

# Email Configuration
EMAIL_FROM=noreply@swipejobs.local
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=

# Stripe
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# AI/ML Services
MATCHING_SERVICE_URL=http://localhost:8000
RECOMMENDATION_SERVICE_URL=http://localhost:8001

# Observability
OTEL_ENABLED=true
OTEL_JAEGER_ENDPOINT=http://localhost:14268/api/traces
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Feature Flags
FEATURE_AI_MATCHING=true
FEATURE_REALTIME_UPDATES=true
FEATURE_MOBILE_APP=true
FEATURE_ANALYTICS=true

# Integrations
WORKDAY_INTEGRATION_ENABLED=false
ADP_INTEGRATION_ENABLED=false
SLACK_INTEGRATION_ENABLED=false
